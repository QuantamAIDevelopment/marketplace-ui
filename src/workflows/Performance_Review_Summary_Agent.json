      "parameters": {
        "jsCode": "const raw = $json.raw_chunk;\n\n// 🧼 Clean malformed JSON (common OpenRouter/OpenAI issues)\nlet cleaned = raw\n  .replace(/,\\s*}/g, '}')\n  .replace(/,\\s*]/g, ']')\n  .replace(/\\\\n/g, '\\n')\n  .replace(/\\\\\"/g, '\"')\n  .replace(/“|”/g, '\"')\n  .replace(/‘|’/g, \"'\");\n\n// 🔍 Helper to extract from raw using RegEx (fallback if parse fails)\nconst extractValue = (key) => {\n  const regex = new RegExp(`\"${key}\"\\\\s*:\\\\s*\"?(.*?)\"?[,}]`, 'i');\n  const match = raw.match(regex);\n  return match ? match[1] : null;\n};\n\n// Extract fields even if parsing fails\nconst employeeId = extractValue(\"employee id\");\nconst name = extractValue(\"name\");\nconst rating = extractValue(\"rating\");\nconst department = extractValue(\"department\");\nconst summary = extractValue(\"summary\");\n\ntry {\n  const parsed = JSON.parse(cleaned);\n\n  return [{\n    json: {\n      ...parsed,\n      employee_id: employeeId || parsed[\"employee id\"] || parsed.employee_id || null,\n      name: name || parsed.name || null,\n      rating: rating || parsed.rating || null,\n      department: department || parsed.department || null,\n      summary: summary || parsed.summary || null,\n      success: true\n    }\n  }];\n} catch (err) {\n  return [{\n    json: {\n      success: false,\n      error_message: err.message,\n      employee_id: employeeId || null,\n      name: name || null,\n      rating: rating || null,\n      department: department || null,\n      summary: summary || null,\n      raw_chunk: raw // ✅ ONLY included here\n    }\n  }];\n}\n"
      },
