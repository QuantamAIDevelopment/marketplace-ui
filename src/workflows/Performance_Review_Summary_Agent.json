      "parameters": {
        "jsCode": "const raw = $json.output || ''; // or replace with the string if outside n8n\n\n// Step 1: Clean the string\nconst cleaned = raw\n  .replace(/^Here is the summary in the requested JSON format:\\s*/i, '')\n  .replace(/\\\\n/g, '')     // Remove escaped newlines\n  .replace(/\\\\\"/g, '\"')    // Replace escaped quotes\n  .replace(/(\\s+)?({)/, '{') // Remove space before JSON\n  .replace(/}(\\s+)?$/, '}')  // Ensure it ends with proper }\n  .trim();\n\n// Step 2: Extract just the JSON content\nconst start = cleaned.indexOf('{');\nconst end = cleaned.lastIndexOf('}');\nconst jsonBlock = cleaned.slice(start, end + 1);\n\n// Step 3: Parse JSON\nlet parsed;\ntry {\n  parsed = JSON.parse(jsonBlock);\n} catch (err) {\n  return [{ json: { error: \"❌ Failed to parse JSON\", raw: raw }}];\n}\n\n// Step 4: Return cleaned and normalized output\nreturn [{\n  json: {\n    employee_id: parsed[\"employee id\"] || parsed.employee_id || \"Unknown\",\n    employee_name: parsed.name || \"Unknown\",\n    department: parsed.department || \"Unknown\",\n    summary: parsed.summary || \"\",\n    rating: parsed.rating || 0,\n    rating_reason: parsed.rating_reason || \"\",\n    strengths: parsed.strengths || [],\n    improvements: parsed.improvements || [],\n    timestamp: parsed.timestamp || new Date().toISOString()\n  }\n}];\n"
