      "parameters": {
        "jsCode": "const employees = $items().map(i => i.json);\nlet html = `<h2>📬 Employee Performance Summary — Q2 2025</h2>`;\n\nemployees.forEach((emp, i) => {\n  const strengths = Array.isArray(emp.strengths) ? emp.strengths : [];\n  const improvements = Array.isArray(emp.improvements) ? emp.improvements : [];\n\n  html += `\n  <h3>${i + 1}. ${emp.employee_name}</h3>\n  <p><strong>🎯 Department:</strong> ${emp.department}</p>\n  <p><strong>⭐ Overall Rating:</strong> ${emp.applied_rating || emp.rating || 0} / 5</p>\n\n  <p><strong>🔹 Summary:</strong><br/>\n  ${emp.summary || \"No summary provided.\"}</p>\n\n  <p><strong>✅ Strengths:</strong></p>\n  <ul>\n    ${strengths.map(s => `<li>${s}</li>`).join(\"\")}\n  </ul>\n\n  <p><strong>⚠️ Improvement Areas:</strong></p>\n  <ul>\n    ${improvements.map(s => `<li>${s}</li>`).join(\"\")}\n  </ul>\n\n  <p><em>Generated by QAID's Performance Review Summary Agent</em></p>\n  <hr/>\n  `;\n});\n\nreturn [{ json: { htmlBody: html } }];\n"
      },
