    {
      "parameters": {
        "jsCode": "function cleanText(text) {\n  if (!text) return \"\";\n  return text\n    .replace(/(?:hi|hello|dear|thanks|regards|cheers)[.,]*/gi, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nconst now = new Date().toISOString();\nconst processed = [];\n\nfor (const item of items) {\n  const review = item.json;\n\n  // Try both naming formats for different sources\n  const status = review[\"Review Status\"] || review.review_status || \"\";\n  if (status.toLowerCase() !== \"completed\") {\n    continue;\n  }\n\n  const kpiRaw = parseFloat(review[\"KPI Score\"] || review.kpi_score) || 0;\n  const normalizedKPI = Math.round((kpiRaw / 100) * 5 * 10) / 10;\n\n  processed.push({\n    json: {\n      employee_id: review[\"Employee ID\"] || review.employee_id || \"Unknown\",\n      employee_name: review[\"Name\"] || review.employee_name || \"Unknown\",\n      department: review[\"Department\"] || review.department || \"Unknown\",\n      manager_feedback: cleanText(review[\"Manager Feedback\"] || review.manager_feedback),\n      peer_feedback: cleanText(review[\"Peer Feedback\"] || review.peer_feedback),\n      normalized_kpi_score: normalizedKPI,\n      timestamp: review.timestamp || now,\n      source: review.source || \"auto\"\n    }\n  });\n}\n\nif (processed.length === 0) {\n  return [{ json: { message: \"⚠️ No completed reviews to process.\" } }];\n}\n\nreturn processed;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        940,
        -100
      ],
      "id": "21360fba-e544-416f-8aa8-77930537e6e6",
      "name": "Normalize & Filter Reviews",
      "alwaysOutputData": false
    },
    {
      "parameters": {
        "jsCode": "const results = [];\nconst now = new Date().toISOString(); // current timestamp\n\nfor (const item of items) {\n  const raw = item.json.output || '';\n\n  // Step 1: Split by \"}{\" or \"}\\n{\" to separate JSON objects\n  const entries = raw\n    .split(/}\\s*{/g)\n    .map((chunk) => {\n      if (!chunk.startsWith('{')) chunk = '{' + chunk;\n      if (!chunk.endsWith('}')) chunk = chunk + '}';\n      return chunk;\n    });\n\n  // Step 2: Parse each entry\n  for (const rawChunk of entries) {\n    try {\n      const cleaned = rawChunk\n        .replace(/\\\\n/g, '')     // Remove escaped newlines\n        .replace(/\\\\\"/g, '\"')    // Replace escaped quotes\n        .replace(/\\s+/g, ' ')    // Normalize whitespace\n        .trim();\n\n      const parsed = JSON.parse(cleaned);\n\n      results.push({\n        json: {\n          employee_id: parsed[\"employee id\"] || parsed.employee_id || 'Unknown',\n          employee_name: parsed.name || 'Unknown',\n          department: parsed.department || 'Unknown',\n          summary: parsed.summary || '',\n          rating: parsed.rating || 0,\n          rating_reason: parsed.rating_reason || '',\n          strengths: parsed.strengths || [],\n          improvements: parsed.improvements || [],\n          timestamp: now\n        }\n      });\n    } catch (err) {\n      results.push({\n        json: {\n          error: '❌ Failed to parse entry',\n          raw_chunk: rawChunk,\n          timestamp: now\n        }\n      });\n    }\n  }\n}\n\nreturn results;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        -100
      ],
      "id": "5ee4c3e5-2cb8-41ea-8d06-4304ad6ec7c0",
