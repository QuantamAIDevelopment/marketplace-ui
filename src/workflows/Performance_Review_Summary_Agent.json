    {
      "parameters": {
        "jsCode": "function getSentimentScore(text) {\n  const positiveWords = ['excellent', 'great', 'strong', 'outstanding', 'positive', 'collaborative', 'consistent', 'creative'];\n  const negativeWords = ['struggle', 'late', 'poor', 'weak', 'issue', 'lack', 'communication', 'delay'];\n\n  let score = 3;\n  const textLower = text.toLowerCase();\n\n  for (const word of positiveWords) {\n    if (textLower.includes(word)) score += 0.3;\n  }\n\n  for (const word of negativeWords) {\n    if (textLower.includes(word)) score -= 0.3;\n  }\n\n  return Math.max(1, Math.min(5, Math.round(score * 10) / 10));\n}\n\nreturn items.map(item => {\n  const data = item.json;\n\n  const kpi = parseFloat(data.normalized_kpi_score || 0);\n  const ai_rating = parseFloat(data.rating || 0);\n  const managerSentiment = getSentimentScore(data.manager_feedback || '');\n  const peerSentiment = getSentimentScore(data.peer_feedback || '');\n  const sentimentGap = Math.abs(managerSentiment - peerSentiment);\n  const consistencyPenalty = sentimentGap > 1 ? 0.3 : 0;\n\n  let blendedScore = (\n    (kpi * 0.4) +\n    ((managerSentiment + peerSentiment) / 2) * 0.4 +\n    (ai_rating * 0.2)\n  );\n  blendedScore = Math.max(1, Math.min(5, Math.round((blendedScore - consistencyPenalty) * 10) / 10));\n\n  // Clean + validate HR override rating\n  let overrideRaw = data.hr_override_rating;\n  let override = null;\n\n  if (typeof overrideRaw === 'string') {\n    overrideRaw = overrideRaw.trim();\n  }\n\n  const overrideParsed = parseFloat(overrideRaw);\n  if (!isNaN(overrideParsed) && overrideParsed >= 1 && overrideParsed <= 5) {\n    override = overrideParsed;\n  }\n\n  const finalRating = override !== null ? override : blendedScore;\n  const ratingReason = override !== null\n    ? `Overridden by HR to ${override}`\n    : `Blended: KPI (${kpi}), AI (${ai_rating}), Sentiment (${(managerSentiment + peerSentiment) / 2}), Consistency penalty (-${consistencyPenalty})`;\n\n  return {\n    json: {\n      ...data,\n      kpi_score: kpi,\n      ai_rating: ai_rating,\n      manager_sentiment: managerSentiment,\n      peer_sentiment: peerSentiment,\n      sentiment_gap: sentimentGap,\n      consistency_penalty: consistencyPenalty,\n      final_computed_rating: blendedScore,\n      hr_override_rating: override,  // will be null if not valid\n      applied_rating: finalRating,\n      rating_reason: ratingReason\n    }\n  };\n});\n"
      },
